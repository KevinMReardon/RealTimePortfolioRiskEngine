OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
PROMETHEUS_ENABLED=false
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio?sslmode=disable

# Automated price feed configuration
# Docs: docs/implementation/automated_price_feed_ingestion_282b9a66.plan.md (Slice 1)
PRICE_FEED_ENABLED=false
# Currently supported ingestion source: Twelve Data only.
PRICE_FEED_PROVIDER=twelvedata
# Symbols should use internal format accepted by PricePayload (e.g. EUR-USD).
PRICE_FEED_SYMBOLS=AAPL,MSFT,BTC-USD,ETH-USD,EUR-USD
PRICE_FEED_POLL_SECONDS=900
PRICE_FEED_HTTP_TIMEOUT_MS=5000
PRICE_FEED_RETRY_COUNT=3
PRICE_FEED_RETRY_DELAY_MS=500

# Feed quality guards
# Reject upstream quotes whose as-of time is older than this (0 disables).
PRICE_FEED_MAX_QUOTE_AGE_MS=1800000
# Skip unchanged prices within this window to reduce write churn (0 disables).
PRICE_FEED_DEDUP_WINDOW_MS=60000

# Twelve Data credentials
PRICE_FEED_TWELVEDATA_API_KEY=

# Twelve Data request cap (requests per minute)
# Loader safety will raise poll interval if needed so:
# len(PRICE_FEED_SYMBOLS) * 60 / PRICE_FEED_POLL_SECONDS <= PRICE_FEED_TWELVEDATA_RATE_LIMIT_RPM
PRICE_FEED_TWELVEDATA_RATE_LIMIT_RPM=8
